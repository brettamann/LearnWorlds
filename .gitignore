# Auto-installed deps for tooling scripts.
tools/scripts/node_modules/
tools/scripts/package*.json

# Tool outputs (regenerated; not source-of-truth).
tools/tts/harvest-manifest.json
tools/tts/canonical-manifest.json
tools/tts/render-plan.json
tools/tts/voice-samples/
tools/tts/preview-bundle/

# Rendered audio and Stage 5 manifests are generated by the TTS pipeline,
# not source-of-truth. Audio files are large; manifests are derivable from
# the canonical manifest + a real render pass. Exclude both.
assets/narration-manifest.json
assets/**/narration/**/manifest.json
assets/**/*.mp3
assets/**/*.m4a
assets/**/*.hash

# Editor / OS cruft.
.DS_Store
Thumbs.db
*.swp
*.swo

# Flutter — see app/.gitignore for the comprehensive list.
app/.dart_tool/
app/build/

# Personal scratch notes (excluded by default; remove this line if you want them tracked).
human-notes*.txt
