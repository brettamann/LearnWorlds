{
  "$schema": "../../schemas/lesson-runtime.schema.json",
  "id": "lesson-k-md-3-classify-and-sort",
  "specRef": "specs/lessons/k-md-3-classify-and-sort.md",
  "version": 1,
  "conceptId": "K.MD.3",
  "standardCode": "K.MD.3",
  "region": "sanctuary",
  "introducingActivity": "care-pantry",
  "subModeTarget": "simple-pantry",
  "narratorVoice": "sanctuary-warm-naturalist",
  "totalDurationTargetSec": 75,

  "phases": {
    "iShow": {
      "durationSec": 30,
      "scene": {
        "background": "care-pantry-supply-hut",
        "musicBed": "sanctuary-industrious",
        "messItems": [
          { "id": "treat-1", "kind": "treat" }, { "id": "treat-2", "kind": "treat" }, { "id": "treat-3", "kind": "treat" },
          { "id": "bed-1", "kind": "bed" }, { "id": "bed-2", "kind": "bed" },
          { "id": "toy-1", "kind": "toy" }
        ],
        "bins": [
          { "id": "treats-bin", "label": "treats", "icon": "treat", "count": 0 },
          { "id": "beds-bin", "label": "beds", "icon": "bed", "count": 0 },
          { "id": "toys-bin", "label": "toys", "icon": "toy", "count": 0 }
        ],
        "podiumSlots": { "visibility": "hidden-during-phase-1" },
        "buddyPosition": "lower-left-basket",
        "hud": { "doneButton": "hidden" }
      },
      "animationSteps": [
        { "at": "0s",  "action": "scene-fade-up" },
        { "at": "0s",  "action": "music-bed-in" },
        { "at": "2s",  "action": "narrator-begin" },
        { "at": "5s",  "action": "pointer-pickup-drag", "params": { "from": "treat-1", "to": "treats-bin" } },
        { "at": "7s",  "action": "bin-count-update", "params": { "bin": "treats-bin", "value": 1 } },
        { "at": "9s",  "action": "pointer-pickup-drag", "params": { "from": "bed-1", "to": "beds-bin" } },
        { "at": "11s", "action": "pointer-pickup-drag", "params": { "from": "toy-1", "to": "toys-bin" } },
        { "at": "13s", "action": "pointer-auto-sweep-remaining" },
        { "at": "17s", "action": "phase-1-complete-stinger" },
        { "at": "17s", "action": "ive-got-this-button-show" },
        { "at": "20s", "action": "podium-slots-fade-in", "params": { "labels": ["least", "2", "most"] } },
        { "at": "20s", "action": "bins-lift-slightly-draggable" },
        { "at": "22s", "action": "pointer-drag-bin-to-podium", "params": { "bin": "toys-bin", "podium": "least" } },
        { "at": "25s", "action": "pointer-drag-bin-to-podium", "params": { "bin": "beds-bin", "podium": "2" } },
        { "at": "27s", "action": "pointer-drag-bin-to-podium", "params": { "bin": "treats-bin", "podium": "most" } },
        { "at": "29s", "action": "frame-brighten" },
        { "at": "30s", "action": "phase-end" }
      ],
      "narrationScript": [
        { "at": "2s",  "text": "The Caretaker stepped out. Two jobs today." },
        { "at": "5s",  "text": "First, sort the supplies." },
        { "at": "13s", "text": "Treats with treats, beds with beds, toys with toys." },
        { "at": "17s", "text": "All sorted. Now the second job." },
        { "at": "20s", "text": "Put the baskets in order — fewest to most." },
        { "at": "22s", "text": "One — the fewest." },
        { "at": "25s", "text": "Two." },
        { "at": "27s", "text": "Three — the most." },
        { "at": "29s", "text": "Sort the things, then sort the baskets. That's how we tidy." }
      ],
      "skipToYouDoAvailableAfterSec": 17
    },

    "weTry": {
      "durationSec": 25,
      "scene": {
        "background": "care-pantry-supply-hut",
        "messItems": [
          { "id": "wt-treat-1", "kind": "treat" }, { "id": "wt-treat-2", "kind": "treat" }, { "id": "wt-treat-3", "kind": "treat" }, { "id": "wt-treat-4", "kind": "treat" },
          { "id": "wt-bed-1", "kind": "bed" }, { "id": "wt-bed-2", "kind": "bed" },
          { "id": "wt-toy-1", "kind": "toy" }
        ],
        "bins": [
          { "id": "treats-bin", "label": "treats", "count": 0 },
          { "id": "beds-bin", "label": "beds", "count": 0 },
          { "id": "toys-bin", "label": "toys", "count": 0 }
        ],
        "podiumSlots": { "visibility": "hidden-until-phase-2" },
        "initialGlowItem": "wt-treat-1",
        "initialGlowBin": "treats-bin"
      },
      "choreography": [
        { "at": "0s",            "type": "system-action",       "params": { "action": "narration", "cueId": "we-try-phase1-start" } },
        { "at": "0s",            "type": "system-action",       "params": { "action": "halo-pulse-pair", "targets": ["wt-treat-1", "treats-bin"] } },
        { "at": "on-kid-input",  "type": "kid-action-expected", "params": { "expectedAction": "drag-to-bin", "item": "wt-treat-1", "expectedBin": "treats-bin", "wrongReturns": true } },
        { "at": "on-kid-input",  "type": "system-action",       "params": { "action": "bin-count-update", "bin": "treats-bin", "value": 1 } },
        { "at": "on-kid-input",  "type": "system-action",       "params": { "action": "narration", "cueId": "we-try-treat-placed" } },
        { "at": "+0.5s",         "type": "system-action",       "params": { "action": "halo-pulse-pair", "targets": ["wt-bed-1", "beds-bin"] } },
        { "at": "+0.5s",         "type": "system-action",       "params": { "action": "narration", "cueId": "we-try-prompt-bed" } },
        { "at": "on-kid-input",  "type": "kid-action-expected", "params": { "expectedAction": "drag-to-bin", "item": "wt-bed-1", "expectedBin": "beds-bin", "wrongReturns": true } },
        { "at": "on-kid-input",  "type": "system-action",       "params": { "action": "bin-count-update", "bin": "beds-bin", "value": 1 } },
        { "at": "on-kid-input",  "type": "system-action",       "params": { "action": "narration", "cueId": "we-try-bed-placed" } },
        { "at": "+0.5s",         "type": "system-action",       "params": { "action": "pointer-auto-sweep-remaining" } },
        { "at": "+0.5s",         "type": "system-action",       "params": { "action": "narration", "cueId": "we-try-rest" } },
        { "at": "+0.5s",         "type": "system-action",       "params": { "action": "narration", "cueId": "we-try-phase1-end" } },
        { "at": "+1s",           "type": "system-action",       "params": { "action": "podium-slots-fade-in" } },
        { "at": "+1s",           "type": "system-action",       "params": { "action": "bins-lift-draggable" } },
        { "at": "+0.5s",         "type": "system-action",       "params": { "action": "halo-pulse-pair", "targets": ["toys-bin", "podium-least"] } },
        { "at": "+0.5s",         "type": "system-action",       "params": { "action": "narration", "cueId": "we-try-phase2-prompt" } },
        { "at": "on-kid-input",  "type": "kid-action-expected", "params": { "expectedAction": "drag-bin-to-podium", "bin": "toys-bin", "expectedPodium": "least", "wrongReturns": true } },
        { "at": "on-kid-input",  "type": "system-action",       "params": { "action": "narration", "cueId": "we-try-podium-least" } },
        { "at": "+0.5s",         "type": "system-action",       "params": { "action": "pointer-auto-place-remaining-bins" } },
        { "at": "+0.5s",         "type": "system-action",       "params": { "action": "narration", "cueId": "we-try-podium-rest" } },
        { "at": "25s",           "type": "system-action",       "params": { "action": "narration", "cueId": "we-try-closing" } },
        { "at": "25s",           "type": "system-action",       "params": { "action": "phase-end" } }
      ],
      "narrationScript": [
        { "at": "we-try-phase1-start",  "text": "Your turn. Drop this treat in the treats basket." },
        { "at": "we-try-treat-placed",  "text": "One treat." },
        { "at": "we-try-prompt-bed",    "text": "Now this one." },
        { "at": "we-try-bed-placed",    "text": "One bed." },
        { "at": "we-try-rest",          "text": "And the rest." },
        { "at": "we-try-phase1-end",    "text": "All sorted." },
        { "at": "we-try-phase2-prompt", "text": "This basket has the fewest. Drag it to 'least'." },
        { "at": "we-try-podium-least",  "text": "Fewest." },
        { "at": "we-try-podium-rest",   "text": "Two. Most." },
        { "at": "we-try-closing",       "text": "All in order. Nicely done." }
      ],
      "hesitationRule": {
        "thresholdSec": 5,
        "action": "highlight-target"
      },
      "passCondition": "Any kid drag onto any valid target passes. Even one drag in each phase is enough; system completes the rest."
    },

    "youDo": {
      "activityId": "care-pantry",
      "subMode": "simple-pantry",
      "isContinuation": false,
      "roundParameters": {
        "categoryCount": 3,
        "itemsPerCategory": { "category-A": 3, "category-B": 2, "category-C": 1 },
        "phasesRun": ["phase-1-categorize", "phase-2-sort-by-count"],
        "binIconAndTextAtConcrete": true,
        "podiumLabels": ["least", "2", "most"],
        "hintThresholds": {
          "highlightNextSec": 5,
          "narratorReminderSec": 10
        }
      },
      "maxAttempts": 3,
      "cpaLayer": "Concrete"
    }
  },

  "libraryEntry": {
    "thumbnail": "assets/lessons/k-md-3/thumbnail.png",
    "shortLabel": "Sort, then sort again",
    "regionBadge": "sanctuary-leaf",
    "replayDurationSec": 75
  },

  "telemetryExtensions": []
}
